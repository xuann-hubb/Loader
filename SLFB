    while task.wait(0.1) do
        if autoCollectCheese and cheeseHRP then
            pcall(function()
                local cheeseModel = workspace:FindFirstChild("GameFolder")
                    and workspace.GameFolder:FindFirstChild("CheeseFolder")
                    and workspace.GameFolder.CheeseFolder:FindFirstChild("CheeseModel")
                if not cheeseModel then return end

                for _, cheese in ipairs(cheeseModel:GetChildren()) do
                    if not autoCollectCheese then break end

                    local part = (cheese:IsA("BasePart") and cheese)
                        or cheese:FindFirstChildWhichIsA("BasePart")

                    if part then
                        cheeseHRP.CFrame = part.CFrame
                        task.wait(1) -- 1 second between each cheese
                    end
                end
            end)
        end
    end
end)

